# Maven 构建输出目录
/target/

# IntelliJ IDEA 工程文件
/.idea/
*.iml

# Maven Wrapper 目录默认忽略，但保留可执行的 wrapper jar
/.mvn/
!.mvn/wrapper/maven-wrapper.jar

# 保留源码目录下可能存在的示例 target 结构
!**/src/main/**/target/
!**/src/test/**/target/

# 本地日志与运行输出
/log/
*.log
*.out
*.err

# macOS 系统文件
.DS_Store

# 本地环境变量与临时覆盖配置
.env
.env.*
application-local.yml
application-secrets.yml

# 临时文件与编辑器交换文件
*.swp
*.swo
*~
